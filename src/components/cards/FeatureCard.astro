---
import Card from '../shared/Card.astro';
import SectionLabel from '../shared/SectionLabel.astro';

interface Props {
  title: string;
  label?: string;
  colspan?: 1 | 2 | 3;
  accent?: 'green' | 'amber' | 'red' | 'earth';
  stagger?: number;
}

const {
  title,
  label,
  colspan = 1,
  accent,
  stagger
} = Astro.props;
---

<Card colspan={colspan} accent={accent} stagger={stagger} class="flex flex-col gap-4">
  {label && <SectionLabel label={label} />}
  <h3 class="font-display text-lg font-medium text-text leading-tight">
    {title}
  </h3>
  <div class="text-text-secondary text-sm leading-relaxed">
    <slot />
  </div>
</Card>
