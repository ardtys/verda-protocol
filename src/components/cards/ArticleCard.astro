---
import DarkCard from '../shared/DarkCard.astro';
import { ArrowUpRight, Leaf } from '@lucide/astro';

interface Props {
  title: string;
  subtitle: string;
  href?: string;
  colspan?: 1 | 2 | 3;
  stagger?: number;
}

const {
  title,
  subtitle,
  href = '#',
  colspan = 1,
  stagger
} = Astro.props;
---

<a
  href={href}
  class="block no-underline"
>
  <DarkCard colspan={colspan} interactive stagger={stagger} class="relative min-h-[180px] flex flex-col justify-between">
    <div class="flex items-start justify-between">
      <div class="w-8 h-8 rounded-full bg-green-bg flex items-center justify-center">
        <Leaf class="w-4 h-4 text-green-light" />
      </div>
    </div>

    <div class="mt-auto">
      <h3 class="font-display text-base font-medium leading-tight mb-2">
        {title}
      </h3>
      <p class="text-muted text-xs leading-relaxed">
        {subtitle}
      </p>
    </div>

    <div class="external-link-arrow absolute bottom-4 right-4">
      <ArrowUpRight class="w-4 h-4" />
    </div>
  </DarkCard>
</a>
