---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['absolute inset-0 w-full h-full pointer-events-none', className]}
  viewBox="0 0 100 100"
  preserveAspectRatio="none"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M10 20 Q25 25 30 40 T50 50 T70 45 T90 60"
    stroke="rgba(45, 90, 39, 0.08)"
    stroke-width="0.3"
    stroke-dasharray="2 2"
    fill="none"
  />
  <circle cx="10" cy="20" r="1" fill="rgba(45, 90, 39, 0.15)" />
  <circle cx="30" cy="40" r="0.8" fill="rgba(45, 90, 39, 0.12)" />
  <circle cx="50" cy="50" r="0.8" fill="rgba(45, 90, 39, 0.12)" />
  <circle cx="70" cy="45" r="0.8" fill="rgba(45, 90, 39, 0.12)" />
  <circle cx="90" cy="60" r="1" fill="rgba(45, 90, 39, 0.15)" />
</svg>
