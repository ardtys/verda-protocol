---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Mail, MapPin, Linkedin, Twitter, Github, ArrowRight, Target, Heart, Globe, Users, Award, Calendar } from '@lucide/astro';
---

<BaseLayout
  title="About"
  description="Learn about Verda's mission to bring transparency to the global food supply chain. Meet our team of food scientists, engineers, and blockchain experts."
>
  <div class="container">
    <!-- Hero -->
    <section class="hero hero-animated particles reveal">
      <span class="badge badge-pulse mb-4">About Us</span>
      <h1 class="italic text-shimmer"><span class="gradient-text-animated">Everyone deserves to know</span> what they're eating.</h1>
      <p class="text-base max-w-2xl">
        Verda exists because the global food system was designed for opacity.
        Technology can now make transparency the default.
      </p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="mailto:hello@verda.so" class="btn btn-lg glow-green ripple">
          Get in Touch
          <ArrowRight class="icon-sm" />
        </a>
        <a href="/technology" class="btn btn-outline btn-lg ripple">
          View Our Tech
        </a>
      </div>
    </section>

    <hr class="divider-gradient" />

    <!-- Mission -->
    <section class="reveal">
      <span class="section-label section-label-animated">mission</span>
      <h2><span class="highlight">Why We Exist</span></h2>
      <p>
        For decades, complexity in global supply chains has been weaponized to hide fraud,
        cut corners, and externalize risk onto consumers. From <strong class="text-text">fake organic labels</strong>
        to <strong class="text-text">adulterated olive oil</strong>, from mislabeled seafood to compromised cold chains —
        the system rewards opacity.
      </p>
      <p>
        We're building the infrastructure to change that. Every product should have a verifiable story.
        Every consumer should have access to the truth. Every honest producer should be able to prove it.
      </p>

      <div class="grid-3 mt-6 stagger-children">
        <div class="card card-3d glow-hover text-center">
          <div class="feature-icon feature-icon-lg cyan feature-icon-animated mx-auto mb-3 glow-pulse">
            <Target class="icon-lg" />
          </div>
          <h3 class="text-base mb-1 underline-animated">Our Vision</h3>
          <p class="text-sm mb-0">A world where every food product has a verifiable, transparent history.</p>
        </div>
        <div class="card card-3d glow-hover text-center">
          <div class="feature-icon feature-icon-lg rose feature-icon-animated mx-auto mb-3 heartbeat">
            <Heart class="icon-lg" />
          </div>
          <h3 class="text-base mb-1 underline-animated">Our Mission</h3>
          <p class="text-sm mb-0">Make supply chain transparency the default, not the exception.</p>
        </div>
        <div class="card card-3d glow-hover text-center">
          <div class="feature-icon feature-icon-lg indigo feature-icon-animated mx-auto mb-3">
            <Globe class="icon-lg" />
          </div>
          <h3 class="text-base mb-1 underline-animated">Our Impact</h3>
          <p class="text-sm mb-0">Protecting consumers and empowering honest producers worldwide.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Problem -->
    <section class="reveal">
      <span class="section-label section-label-animated">the problem</span>
      <h2><span class="gradient-text">Why This Matters</span></h2>

      <div class="grid-3 mb-6 stagger-children">
        <div class="stat-card card card-3d gradient-border">
          <span class="stat-number rose text-shimmer">$40B+</span>
          <p class="text-sm mt-2 mb-0">annual food fraud</p>
          <div class="progress-bar progress-bar-animated mt-3">
            <div class="progress-fill" style="width: 85%; background: var(--color-rose);"></div>
          </div>
        </div>
        <div class="stat-card card card-3d gradient-border">
          <span class="stat-number orange">$35B</span>
          <p class="text-sm mt-2 mb-0">cold chain losses</p>
          <div class="progress-bar progress-bar-animated mt-3">
            <div class="progress-fill" style="width: 70%; background: var(--color-orange);"></div>
          </div>
        </div>
        <div class="stat-card card card-3d gradient-border">
          <span class="stat-number cyan">600M</span>
          <p class="text-sm mt-2 mb-0">people sick yearly</p>
          <div class="progress-bar progress-bar-animated mt-3">
            <div class="progress-fill" style="width: 90%; background: var(--color-cyan);"></div>
          </div>
        </div>
      </div>

      <div class="card mb-4">
        <h3 class="text-base mb-2">Food Fraud</h3>
        <p class="text-sm mb-0">
          $40B+ annually. Olive oil cut with cheaper oils. Honey adulterated with corn syrup.
          "Organic" labels on conventional produce. "Wild-caught" on farmed fish.
          Systemic deception at industrial scale.
        </p>
      </div>

      <div class="card mb-4">
        <h3 class="text-base mb-2">Cold Chain Failures</h3>
        <p class="text-sm mb-0">
          $35B in annual losses from temperature excursions. Vaccines, seafood, dairy —
          they all need controlled temperatures. Most failures go undetected until someone gets sick.
        </p>
      </div>

      <div class="card mb-4">
        <h3 class="text-base mb-2">Recall Nightmares</h3>
        <p class="text-sm mb-0">
          Average food recall takes 2-3 weeks. By then, contaminated products are consumed.
          Without granular tracing, entire batches are destroyed — massive waste, incomplete protection.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Team -->
    <section class="reveal gradient-bg-animated section-full">
      <span class="section-label section-label-animated">team</span>
      <h2><span class="highlight">Who We Are</span></h2>
      <p class="mb-6 max-w-2xl">
        A team of food industry veterans, blockchain engineers, and IoT specialists
        united by a shared belief: transparency should be the default.
      </p>

      <div class="grid-4 stagger-children">
        <div class="card card-3d glass">
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-cyan-bg flex items-center justify-center mx-auto mb-3 pulse-ring">
              <span class="text-xl">SC</span>
            </div>
            <h3 class="text-base mb-0 underline-animated">Sarah Chen</h3>
            <p class="text-xs text-cyan mb-2">CEO & Co-founder</p>
            <p class="text-sm mb-3">Former supply chain lead at Nestlé. 15 years in food logistics. MIT MBA.</p>
            <div class="flex gap-2 justify-center">
              <a href="#" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="LinkedIn"><Linkedin class="icon-sm" /></a>
              <a href="#" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="Twitter"><Twitter class="icon-sm" /></a>
            </div>
          </div>
        </div>

        <div class="card card-3d glass">
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-orange-bg flex items-center justify-center mx-auto mb-3">
              <span class="text-xl">AP</span>
            </div>
            <h3 class="text-base mb-0 underline-animated">Adi Pratama</h3>
            <p class="text-xs text-orange mb-2">CTO & Co-founder</p>
            <p class="text-sm mb-3">Ex-Google engineer. Built Indonesia's largest logistics platform. Blockchain contributor.</p>
            <div class="flex gap-2 justify-center">
              <a href="#" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="LinkedIn"><Linkedin class="icon-sm" /></a>
              <a href="#" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="GitHub"><Github class="icon-sm" /></a>
            </div>
          </div>
        </div>

        <div class="card card-3d glass">
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-indigo-bg flex items-center justify-center mx-auto mb-3">
              <span class="text-xl">MS</span>
            </div>
            <h3 class="text-base mb-0 underline-animated">Dr. Maria Santos</h3>
            <p class="text-xs text-indigo mb-2">Chief Science Officer</p>
            <p class="text-sm mb-3">Food safety researcher. 20+ publications on traceability. Former WHO consultant.</p>
            <div class="flex gap-2 justify-center">
              <a href="#" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="LinkedIn"><Linkedin class="icon-sm" /></a>
            </div>
          </div>
        </div>

        <div class="card card-3d glass">
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-rose-bg flex items-center justify-center mx-auto mb-3">
              <span class="text-xl">JO</span>
            </div>
            <h3 class="text-base mb-0 underline-animated">James Okonkwo</h3>
            <p class="text-xs text-rose mb-2">Head of Engineering</p>
            <p class="text-sm mb-3">Built IoT platforms at 3 startups. Embedded systems specialist. Rust evangelist.</p>
            <div class="flex gap-2 justify-center">
              <a href="#" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="LinkedIn"><Linkedin class="icon-sm" /></a>
              <a href="#" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="GitHub"><Github class="icon-sm" /></a>
            </div>
          </div>
        </div>
      </div>

      <div class="callout mt-6">
        <p class="text-sm mb-0">
          <strong>We're hiring!</strong> Looking for engineers who want to solve hard problems
          with real-world impact. <a href="mailto:careers@verda.so" class="link-underline">See open roles →</a>
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Advisors -->
    <section class="reveal">
      <span class="section-label section-label-animated">advisors</span>
      <h2><span class="gradient-text">Advisory Board</span></h2>
      <p class="mb-6 max-w-2xl">Industry veterans guiding our strategy and opening doors.</p>

      <div class="grid-4 stagger-children">
        <div class="card card-shine">
          <h3 class="text-base mb-0 underline-animated">Prof. David Liu</h3>
          <p class="text-xs text-green-deep mb-2">Blockchain Security, Stanford</p>
          <p class="text-sm mb-0">Leading researcher in cryptographic protocols. Advising on ZK implementation.</p>
        </div>
        <div class="card card-shine">
          <h3 class="text-base mb-0 underline-animated">Anna Kowalski</h3>
          <p class="text-xs text-amber mb-2">Food Regulation, ex-FDA</p>
          <p class="text-sm mb-0">20 years at FDA overseeing food safety compliance. Global regulatory guidance.</p>
        </div>
        <div class="card card-shine">
          <h3 class="text-base mb-0 underline-animated">Rajan Patel</h3>
          <p class="text-xs text-teal mb-2">IoT & Hardware, ex-Cisco</p>
          <p class="text-sm mb-0">Built Cisco's IoT division. Advising on sensor hardware and connectivity.</p>
        </div>
        <div class="card card-shine">
          <h3 class="text-base mb-0 underline-animated">Lisa Tanaka</h3>
          <p class="text-xs text-purple mb-2">Consumer Products, ex-Unilever</p>
          <p class="text-sm mb-0">Former VP of Sustainability at Unilever. Go-to-market strategy.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Values -->
    <section class="reveal">
      <span class="section-label section-label-animated">values</span>
      <h2><span class="highlight">How We Work</span></h2>

      <div class="timeline mt-6">
        <div class="timeline-item">
          <h3 class="text-base mb-1">Truth Over Convenience</h3>
          <p class="text-sm mb-2">
            Real transparency means showing uncomfortable data too. Cold chain breaks,
            delayed shipments, certification gaps — hiding problems doesn't fix them.
          </p>
          <div class="flex gap-1">
            <span class="tag">Core Value</span>
          </div>
        </div>

        <div class="timeline-item">
          <h3 class="text-base mb-1">Farmers First</h3>
          <p class="text-sm mb-2">
            Technology should empower producers, not burden them. Our tools work offline,
            in local languages, on $50 smartphones.
          </p>
          <div class="flex gap-1">
            <span class="tag">Accessibility</span>
          </div>
        </div>

        <div class="timeline-item">
          <h3 class="text-base mb-1">Open Standards</h3>
          <p class="text-sm mb-2">
            Food traceability shouldn't be a walled garden. We're building protocols, not just products.
            Interoperability is a feature, not an afterthought.
          </p>
          <div class="flex gap-1">
            <span class="tag">Open Source</span>
          </div>
        </div>

        <div class="timeline-item">
          <h3 class="text-base mb-1">Ship Fast, Learn Faster</h3>
          <p class="text-sm mb-2">
            Real-world feedback beats theoretical perfection. We pilot quickly, measure obsessively,
            and iterate based on data.
          </p>
          <div class="flex gap-1">
            <span class="tag">Agile</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Recognition -->
    <section class="reveal gradient-bg-animated section-full">
      <span class="section-label section-label-animated">recognition</span>
      <h2><span class="gradient-text">Awards & Recognition</span></h2>

      <div class="grid-3 mt-6 stagger-children">
        <div class="card card-shine text-center">
          <div class="feature-icon feature-icon-lg green feature-icon-animated mx-auto mb-3 glow-pulse">
            <Award class="icon-lg" />
          </div>
          <h3 class="text-base mb-1 underline-animated">Blockchain Hackathon</h3>
          <p class="text-sm text-text-muted mb-0">Winner 2024</p>
        </div>
        <div class="card card-shine text-center">
          <div class="feature-icon feature-icon-lg amber feature-icon-animated mx-auto mb-3">
            <Award class="icon-lg" />
          </div>
          <h3 class="text-base mb-1 underline-animated">TechCrunch Disrupt</h3>
          <p class="text-sm text-text-muted mb-0">Finalist</p>
        </div>
        <div class="card card-shine text-center">
          <div class="feature-icon feature-icon-lg teal feature-icon-animated mx-auto mb-3">
            <Award class="icon-lg" />
          </div>
          <h3 class="text-base mb-1 underline-animated">Y Combinator</h3>
          <p class="text-sm text-text-muted mb-0">W24 Batch</p>
        </div>
      </div>

      <div class="callout mt-6">
        <p class="text-sm mb-0">
          <strong>Press Kit:</strong> Download logos, screenshots, and company information.
          <a href="mailto:press@verda.so" class="link-underline underline-animated">Request press kit →</a>
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Timeline -->
    <section class="reveal">
      <span class="section-label section-label-animated">timeline</span>
      <h2><span class="highlight">Our Journey</span></h2>

      <div class="timeline mt-6">
        <div class="timeline-item">
          <div class="flex items-center gap-2 mb-1">
            <Calendar class="icon-sm text-text-muted" />
            <span class="text-xs text-text-muted">Q1 2023</span>
          </div>
          <h3 class="text-base mb-1">Idea Born</h3>
          <p class="text-sm mb-0">Sarah and Adi meet at a food safety conference. The idea for Verda is born.</p>
        </div>
        <div class="timeline-item">
          <div class="flex items-center gap-2 mb-1">
            <Calendar class="icon-sm text-text-muted" />
            <span class="text-xs text-text-muted">Q3 2023</span>
          </div>
          <h3 class="text-base mb-1">First Prototype</h3>
          <p class="text-sm mb-0">Working prototype demonstrated to potential partners. First pilot agreement signed.</p>
        </div>
        <div class="timeline-item">
          <div class="flex items-center gap-2 mb-1">
            <Calendar class="icon-sm text-text-muted" />
            <span class="text-xs text-text-muted">Q1 2024</span>
          </div>
          <h3 class="text-base mb-1">Y Combinator</h3>
          <p class="text-sm mb-0">Accepted into YC W24 batch. Raised seed funding.</p>
        </div>
        <div class="timeline-item">
          <div class="flex items-center gap-2 mb-1">
            <Calendar class="icon-sm text-text-muted" />
            <span class="text-xs text-text-muted">Q2 2024</span>
          </div>
          <h3 class="text-base mb-1">Production Launch</h3>
          <p class="text-sm mb-0">First supply chain goes live. 100+ products tracked daily.</p>
        </div>
        <div class="timeline-item">
          <div class="flex items-center gap-2 mb-1">
            <Calendar class="icon-sm text-text-muted" />
            <span class="text-xs text-text-muted">Now</span>
          </div>
          <h3 class="text-base mb-1">Scaling</h3>
          <p class="text-sm mb-0">Expanding to multiple supply chains. Building partnerships across Southeast Asia.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Contact -->
    <section class="reveal pb-8">
      <span class="section-label section-label-animated">contact</span>
      <h2><span class="gradient-text-animated">Get in Touch</span></h2>

      <div class="grid-2 mt-6">
        <div class="card card-shine">
          <h3 class="text-base mb-3 underline-animated">General Inquiries</h3>
          <a href="mailto:hello@verda.so" class="flex items-center gap-3 text-text-secondary hover:text-green-deep mb-3">
            <Mail class="icon-md" />
            <span>hello@verda.so</span>
          </a>
          <div class="flex gap-3">
            <a href="https://twitter.com/verda_protocol" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="Twitter">
              <Twitter class="icon-md" />
            </a>
            <a href="https://linkedin.com/company/verda" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="LinkedIn">
              <Linkedin class="icon-md" />
            </a>
            <a href="https://github.com/verda-protocol" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-green-deep tooltip" data-tooltip="GitHub">
              <Github class="icon-md" />
            </a>
          </div>
        </div>

        <div class="card card-shine">
          <h3 class="text-base mb-3 underline-animated">Locations</h3>
          <div class="flex items-start gap-3 mb-3">
            <MapPin class="icon-md text-green-deep flex-shrink-0" />
            <div>
              <p class="text-sm mb-0"><strong>Jakarta, Indonesia</strong></p>
              <p class="text-xs text-text-muted mb-0">APAC Headquarters</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <MapPin class="icon-md text-teal flex-shrink-0" />
            <div>
              <p class="text-sm mb-0"><strong>San Francisco, CA</strong></p>
              <p class="text-xs text-text-muted mb-0">US Office</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mt-6">
        <a href="mailto:hello@verda.so" class="btn btn-lg glow-green ripple">
          Request a Demo
          <ArrowRight class="icon-sm" />
        </a>
        <a href="mailto:careers@verda.so" class="btn btn-outline btn-lg ripple">
          Join Our Team
        </a>
      </div>

      <!-- Status indicator -->
      <div class="flex items-center gap-2 mt-6 text-sm text-text-muted">
        <span class="status-dot online"></span>
        <span>We typically respond within 24 hours</span>
      </div>
    </section>
  </div>
</BaseLayout>
