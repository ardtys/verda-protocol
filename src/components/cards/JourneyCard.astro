---
import Card from '../shared/Card.astro';

interface JourneyStep {
  icon: string;
  label: string;
}

interface Props {
  title?: string;
  steps?: JourneyStep[];
  colspan?: 1 | 2 | 3;
  stagger?: number;
}

const defaultSteps: JourneyStep[] = [
  { icon: '🌱', label: 'Farm' },
  { icon: '🏭', label: 'Process' },
  { icon: '❄️', label: 'Transit' },
  { icon: '🏪', label: 'Retail' },
  { icon: '📱', label: 'Scan' },
  { icon: '⛓️', label: 'Chain' }
];

const { title = 'Data Flow Pipeline', steps = defaultSteps, colspan = 2, stagger } = Astro.props;
---

<Card colspan={colspan} stagger={stagger} class="overflow-hidden">
  <div class="flex items-center justify-between mb-3 sm:mb-4">
    <span class="section-label m-0">{title}</span>
    <span class="text-[9px] sm:text-[10px] text-text-muted font-mono">Live</span>
  </div>

  <div class="relative py-2 overflow-x-auto">
    <!-- Connection line -->
    <div class="absolute top-1/2 left-0 right-0 h-0.5 bg-gradient-to-r from-green-bg via-green to-green-deep -translate-y-1/2 min-w-[280px]"></div>

    <!-- Steps -->
    <div class="relative flex justify-between min-w-[280px] gap-1">
      {steps.map((step, index) => (
        <div class="flex flex-col items-center text-center relative z-10 group">
          <div class="w-8 h-8 sm:w-10 sm:h-10 rounded-full bg-surface border-2 border-green flex items-center justify-center mb-1 sm:mb-2 text-sm sm:text-base shadow-sm">
            {step.icon}
          </div>
          <span class="font-mono text-[8px] sm:text-[10px] text-text-secondary leading-tight">
            {step.label}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Progress indicator -->
  <div class="flex items-center justify-between mt-3 sm:mt-4 pt-3 border-t border-border">
    <span class="text-[9px] sm:text-[10px] text-text-muted">Processing time</span>
    <span class="text-[10px] sm:text-xs font-mono text-green font-medium">~2.4s avg</span>
  </div>
</Card>
