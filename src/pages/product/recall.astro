---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Shield, Clock, Target, Bell, FileText, ArrowRight, AlertTriangle, CheckCircle, Users, Zap } from '@lucide/astro';
---

<BaseLayout
  title="Smart Recall System"
  description="Surgical precision recalls in minutes instead of weeks. Only affected items pulled. Reduce waste, protect consumers, limit liability."
>
  <div class="container">
    <!-- Hero -->
    <section class="py-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="feature-icon red">
          <Shield class="icon-md" />
        </div>
        <span class="badge">Safety System</span>
      </div>
      <h1>Smart Recall System</h1>
      <p class="max-w-lg">
        Traditional recalls take weeks and destroy millions in unaffected product.
        Verda's granular tracing enables surgical precision: pull only what's actually
        contaminated, in minutes instead of weeks.
      </p>
      <div class="flex flex-wrap gap-3 mt-6">
        <a href="mailto:hello@verda.so" class="btn btn-lg">
          Request Demo
          <ArrowRight class="icon-sm" />
        </a>
        <a href="/technology" class="btn btn-outline btn-lg">
          Technical Docs
        </a>
      </div>
    </section>

    <hr class="divider" />

    <!-- The Problem -->
    <section class="reveal">
      <span class="section-label">the problem</span>
      <h2>Why Recalls Are Broken</h2>

      <div class="card mb-4">
        <h3 class="text-base mb-2">Weeks to Execute</h3>
        <p class="text-sm mb-0">
          Average food recall takes 2-3 weeks from detection to completion.
          By then, contaminated products are consumed, distributed further, or forgotten
          in consumers' refrigerators.
        </p>
      </div>

      <div class="card mb-4">
        <h3 class="text-base mb-2">Massive Over-Recall</h3>
        <p class="text-sm mb-0">
          Without granular tracing, companies recall entire production runs.
          A contamination affecting 100 units leads to destroying 100,000.
          Billions in unnecessary waste annually.
        </p>
      </div>

      <div class="card mb-4">
        <h3 class="text-base mb-2">Consumer Notification Fails</h3>
        <p class="text-sm mb-0">
          Press releases and store notices reach maybe 20% of affected consumers.
          The rest never know they have recalled products at home.
        </p>
      </div>

      <div class="card">
        <h3 class="text-base mb-2">Liability Limbo</h3>
        <p class="text-sm mb-0">
          Without precise records, it's impossible to prove where contamination occurred.
          Everyone blames everyone else. Legal battles drag on for years.
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Our Solution -->
    <section class="reveal">
      <span class="section-label">our solution</span>
      <h2>Surgical Precision</h2>

      <div class="timeline mt-6">
        <div class="timeline-item">
          <h3 class="text-base mb-1">Detection</h3>
          <p class="text-sm mb-2">
            Problem identified — lab result, consumer complaint, IoT alert.
            Contaminated batch ID entered into Verda.
          </p>
          <div class="flex gap-1">
            <span class="tag">Instant</span>
          </div>
        </div>
        <div class="timeline-item">
          <h3 class="text-base mb-1">Trace Forward</h3>
          <p class="text-sm mb-2">
            System instantly identifies every unit from affected batch.
            Current location: retailer shelf, consumer home, still in transit.
          </p>
          <div class="flex gap-1">
            <span class="tag">&lt;30 seconds</span>
          </div>
        </div>
        <div class="timeline-item">
          <h3 class="text-base mb-1">Trace Backward</h3>
          <p class="text-sm mb-2">
            Identify contamination source. Which farm? Which processing line?
            Which ingredient batch? Pinpoint root cause.
          </p>
          <div class="flex gap-1">
            <span class="tag">Full History</span>
          </div>
        </div>
        <div class="timeline-item">
          <h3 class="text-base mb-1">Targeted Notification</h3>
          <p class="text-sm mb-2">
            Retailers receive exact shelf locations to pull. Consumers who scanned
            the QR code get push notifications. Direct, not broadcast.
          </p>
          <div class="flex gap-1">
            <span class="tag">SMS</span>
            <span class="tag">App</span>
            <span class="tag">Email</span>
          </div>
        </div>
        <div class="timeline-item">
          <h3 class="text-base mb-1">Execution Tracking</h3>
          <p class="text-sm mb-2">
            Real-time dashboard shows recall progress. Which stores have pulled?
            Which are still pending? Accountability at every step.
          </p>
          <div class="flex gap-1">
            <span class="tag">Dashboard</span>
            <span class="tag">Reports</span>
          </div>
        </div>
        <div class="timeline-item">
          <h3 class="text-base mb-1">Documentation</h3>
          <p class="text-sm mb-2">
            Complete audit trail for regulators and legal. Timestamped, immutable,
            cryptographically verified. Proof of due diligence.
          </p>
          <div class="flex gap-1">
            <span class="tag">Blockchain</span>
            <span class="tag">Compliance</span>
          </div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Comparison -->
    <section class="reveal">
      <span class="section-label">comparison</span>
      <h2>Traditional vs. Verda Recall</h2>

      <div class="grid-2 mt-6">
        <div class="card card-no-hover">
          <h3 class="text-base mb-3 text-red-soft">Traditional Recall</h3>
          <ul class="list-dash">
            <li>2-3 weeks to complete</li>
            <li>Recall entire production run</li>
            <li>20% consumer notification rate</li>
            <li>Paper-based documentation</li>
            <li>Uncertain contamination source</li>
            <li>High legal liability</li>
          </ul>
        </div>

        <div class="card card-no-hover" style="border-color: var(--color-green-deep);">
          <h3 class="text-base mb-3 text-green-deep">Verda Smart Recall</h3>
          <ul class="list-dash">
            <li>Hours to complete</li>
            <li>Recall only affected units</li>
            <li>Direct notification to scanners</li>
            <li>Immutable blockchain records</li>
            <li>Pinpoint contamination source</li>
            <li>Documented due diligence</li>
          </ul>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Impact -->
    <section class="reveal">
      <span class="section-label">impact</span>
      <h2>Measured Results</h2>

      <div class="grid-3 mt-6 stagger-children">
        <div class="card card-no-hover text-center">
          <span class="stat-number green">96%</span>
          <p class="text-sm mt-2 mb-0">Faster recall execution</p>
        </div>
        <div class="card card-no-hover text-center">
          <span class="stat-number amber">89%</span>
          <p class="text-sm mt-2 mb-0">Reduction in waste</p>
        </div>
        <div class="card card-no-hover text-center">
          <span class="stat-number earth">4x</span>
          <p class="text-sm mt-2 mb-0">Higher notification rate</p>
        </div>
      </div>

      <div class="card card-dark mt-6">
        <span class="badge new mb-3">Case Study</span>
        <h3 class="text-base mb-2" style="color: #faf8f4">Regional Dairy Producer</h3>
        <p class="text-sm mb-0">
          "A contamination was detected on Friday afternoon. By Monday morning,
          we had pulled exactly 847 affected units from 23 stores. Without Verda,
          we would have recalled 50,000 units and it would have taken two weeks.
          The system literally paid for itself in one incident."
        </p>
        <p class="text-xs text-text-muted mt-3 mb-0">
          — Quality Assurance Manager, Susu Segar Indonesia
        </p>
      </div>
    </section>

    <hr class="divider" />

    <!-- Compliance -->
    <section class="reveal">
      <span class="section-label">compliance</span>
      <h2>Regulatory Ready</h2>

      <p>
        Verda's recall system is designed for regulatory compliance across major markets.
      </p>

      <div class="grid-2 mt-6">
        <div class="card">
          <h3 class="text-base mb-2">FDA FSMA 204</h3>
          <p class="text-sm mb-0">
            Full compliance with Food Traceability Rule requirements.
            Key Data Elements (KDEs) captured at every Critical Tracking Event (CTE).
          </p>
        </div>
        <div class="card">
          <h3 class="text-base mb-2">EU Food Safety</h3>
          <p class="text-sm mb-0">
            Compliant with Regulation (EC) 178/2002 traceability requirements
            and RASFF notification protocols.
          </p>
        </div>
        <div class="card">
          <h3 class="text-base mb-2">BPOM Indonesia</h3>
          <p class="text-sm mb-0">
            Meets Indonesian Food and Drug Authority requirements for
            food traceability and recall management.
          </p>
        </div>
        <div class="card">
          <h3 class="text-base mb-2">GS1 Standards</h3>
          <p class="text-sm mb-0">
            Full support for GS1 GTIN, SSCC, and EPCIS standards.
            Interoperable with existing supply chain systems.
          </p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Integration -->
    <section class="reveal">
      <span class="section-label">integration</span>
      <h2>Works With Your Systems</h2>

      <ul class="list-dash">
        <li><strong>ERP integration:</strong> SAP, Oracle, Microsoft Dynamics connectors</li>
        <li><strong>WMS integration:</strong> Real-time inventory sync</li>
        <li><strong>POS integration:</strong> Retail notification at checkout</li>
        <li><strong>Webhook API:</strong> Custom integrations for any system</li>
        <li><strong>Regulatory reporting:</strong> Auto-generate FDA, EU, local reports</li>
      </ul>
    </section>

    <hr class="divider" />

    <!-- CTA -->
    <section class="reveal pb-8">
      <span class="section-label">get started</span>
      <h2>Be Ready Before the Crisis Hits</h2>
      <p>
        The best time to implement recall readiness is before you need it.
        Let us show you how Verda transforms recall management.
      </p>
      <div class="flex flex-wrap gap-3 mt-4">
        <a href="mailto:hello@verda.so" class="btn btn-lg">
          Schedule Demo
          <ArrowRight class="icon-sm" />
        </a>
        <a href="/technology/security" class="btn btn-outline btn-lg">
          Security Architecture
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
