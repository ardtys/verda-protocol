---
import Card from '../shared/Card.astro';
import { Linkedin, Twitter } from '@lucide/astro';

interface Props {
  name: string;
  role: string;
  bio?: string;
  initials?: string;
  linkedIn?: string;
  twitter?: string;
  colspan?: 1 | 2 | 3;
  stagger?: number;
}

const {
  name,
  role,
  bio,
  initials,
  linkedIn,
  twitter,
  colspan = 1,
  stagger
} = Astro.props;

const displayInitials = initials || name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
---

<Card colspan={colspan} stagger={stagger} class="flex flex-col gap-3">
  <div class="flex items-start gap-3">
    <!-- Avatar with initials -->
    <div class="w-12 h-12 rounded-full bg-green-bg flex items-center justify-center shrink-0">
      <span class="font-display text-sm font-medium text-green-deep">
        {displayInitials}
      </span>
    </div>

    <div class="min-w-0 flex-1">
      <h4 class="font-display text-sm font-medium text-text truncate">
        {name}
      </h4>
      <span class="font-mono text-xs text-text-muted block">
        {role}
      </span>
    </div>
  </div>

  {bio && (
    <p class="font-mono text-xs text-text-secondary leading-relaxed">
      {bio}
    </p>
  )}

  <!-- Social links -->
  <div class="flex gap-2 mt-auto">
    {linkedIn && (
      <a
        href={linkedIn}
        target="_blank"
        rel="noopener noreferrer"
        class="w-7 h-7 rounded-md bg-surface-2 flex items-center justify-center hover:bg-green-bg transition-colors"
        aria-label={`${name}'s LinkedIn profile`}
      >
        <Linkedin class="w-3.5 h-3.5 text-text-muted" />
      </a>
    )}
    {twitter && (
      <a
        href={twitter}
        target="_blank"
        rel="noopener noreferrer"
        class="w-7 h-7 rounded-md bg-surface-2 flex items-center justify-center hover:bg-green-bg transition-colors"
        aria-label={`${name}'s Twitter profile`}
      >
        <Twitter class="w-3.5 h-3.5 text-text-muted" />
      </a>
    )}
  </div>
</Card>
