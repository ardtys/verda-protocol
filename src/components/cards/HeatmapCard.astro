---
import Card from '../shared/Card.astro';
import Mascot from '../decorative/Mascot.astro';

interface Props {
  message?: string;
  colspan?: 1 | 2 | 3;
  stagger?: number;
}

const { message = '842 journeys verified today.', colspan = 1, stagger } = Astro.props;

// Generate random heatmap data (12 columns x 7 days)
const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const columns = 12;
const days = 7;
const dayLabels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];

// Generate activity levels (0-4)
const generateHeatmapData = () => {
  const data: number[][] = [];
  for (let c = 0; c < columns; c++) {
    const column: number[] = [];
    for (let d = 0; d < days; d++) {
      // More recent columns have higher activity
      const baseLevel = Math.floor(c / 3);
      const randomBoost = Math.random() > 0.5 ? 1 : 0;
      column.push(Math.min(4, baseLevel + randomBoost + Math.floor(Math.random() * 2)));
    }
    data.push(column);
  }
  return data;
};

const heatmapData = generateHeatmapData();

const colorLevels = [
  'bg-surface-2',           // 0 - no activity
  'bg-green-bg',            // 1 - low
  'bg-green-bg-strong',     // 2 - medium-low
  'bg-green-light/40',      // 3 - medium-high
  'bg-green-deep'           // 4 - high
];
---

<Card colspan={colspan} stagger={stagger} class="relative overflow-hidden">
  <div class="flex items-center justify-between mb-4">
    <span class="section-label m-0">Products Verified</span>
    <div class="flex items-center gap-1 text-[10px] text-text-muted">
      <span>Less</span>
      <div class="flex gap-0.5">
        {colorLevels.map((color) => (
          <div class:list={['w-2.5 h-2.5 rounded-sm', color]} />
        ))}
      </div>
      <span>More</span>
    </div>
  </div>

  <div class="flex gap-2">
    <!-- Day labels -->
    <div class="flex flex-col gap-1 pt-5">
      {dayLabels.filter((_, i) => i % 2 === 0).map((day) => (
        <div class="h-3 flex items-center">
          <span class="text-[9px] font-mono text-text-muted leading-none">{day}</span>
        </div>
      ))}
    </div>

    <!-- Heatmap container -->
    <div class="flex-1">
      <!-- Month labels -->
      <div class="flex justify-between mb-1 px-0.5">
        {months.map((month) => (
          <span class="text-[9px] font-mono text-text-muted">{month}</span>
        ))}
      </div>

      <!-- Heatmap grid -->
      <div class="flex gap-1 justify-between">
        {heatmapData.map((column) => (
          <div class="flex flex-col gap-1">
            {column.map((level) => (
              <div
                class:list={[
                  'w-3 h-3 rounded-sm transition-transform hover:scale-125',
                  colorLevels[level],
                  level === 4 && 'pulse-active'
                ]}
                title={`Activity level: ${level}`}
              />
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Message bar at bottom -->
  <div class="flex items-center gap-3 mt-4 pt-3 border-t border-border">
    <Mascot pose="peeking" size="sm" />
    <div class="flex-1 bg-surface-2 rounded-lg px-3 py-2">
      <p class="text-xs font-mono text-text-secondary m-0">{message}</p>
    </div>
  </div>
</Card>
