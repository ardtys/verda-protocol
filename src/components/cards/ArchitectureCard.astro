---
import Card from '../shared/Card.astro';
import SectionLabel from '../shared/SectionLabel.astro';

interface Layer {
  name: string;
  components: string[];
  color: string;
}

interface Props {
  title?: string;
  layers?: Layer[];
  colspan?: 1 | 2 | 3;
  stagger?: number;
  expandable?: boolean;
}

const defaultLayers: Layer[] = [
  {
    name: 'Consumer Interface',
    components: ['QR App', 'Web Portal', 'Brand Widget'],
    color: 'bg-green-deep'
  },
  {
    name: 'Supply Chain Actors',
    components: ['Farmer Dashboard', 'Factory Portal', 'Distributor', 'Retailer POS'],
    color: 'bg-green'
  },
  {
    name: 'IoT & Sensors',
    components: ['Temp Loggers', 'GPS', 'Humidity', 'NFC/RFID'],
    color: 'bg-green-light'
  },
  {
    name: 'Business Logic',
    components: ['Product Registry', 'Journey Composer', 'Certification Engine', 'Anomaly Detector'],
    color: 'bg-amber'
  },
  {
    name: 'Data & Storage',
    components: ['PostgreSQL', 'TimescaleDB', 'IPFS', 'Kafka'],
    color: 'bg-earth'
  },
  {
    name: 'Blockchain Layer',
    components: ['Blockchain Program', 'Merkle Batch', 'Oracle Bridge', 'Verification Contract'],
    color: 'bg-text-secondary'
  }
];

const { title = 'System Architecture', layers = defaultLayers, colspan = 3, stagger, expandable = false } = Astro.props;
---

<Card colspan={colspan} stagger={stagger}>
  <SectionLabel label={title} class="mb-4" />

  <div class="space-y-2">
    {layers.map((layer) => (
      <div class="border border-border rounded-lg overflow-hidden">
        <div class="flex items-center gap-3 p-3 bg-surface-2/50">
          <div class:list={['w-3 h-3 rounded-sm shrink-0', layer.color]} />
          <span class="font-mono text-xs font-medium text-text">
            {layer.name}
          </span>
        </div>
        <div class="px-3 py-2 flex flex-wrap gap-1.5">
          {layer.components.map((component) => (
            <span class="tech-tag">
              {component}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Card>
